<view class="page" style="padding-top:{{navBarHeight + 20}}px">

  <view class="blob blob-1"></view>
  <view class="blob blob-2"></view>
  <view class="blob blob-3"></view>

  <!-- 玻璃导航栏 -->
  <view class="nav-bar" style="padding-top:{{statusBarHeight}}px">
    <text class="nav-title" bindtap="onTitleTap">有点晚拌川</text>
  </view>

  <!-- 消息滚动栏占位 -->
  <view class="scroll-bar-placeholder" wx:if="{{info.announcement}}"></view>
  
  <!-- 消息滚动栏 -->
  <view class="scroll-bar" wx:if="{{info.announcement}}" style="top:{{navBarHeight}}px">
    <text class="scroll-icon">📢</text>
    <view class="scroll-track">
      <text class="scroll-text">{{info.announcement}}</text>
    </view>
  </view>

  <!-- 出摊状态卡 -->
  <view class="status-card">
    <view class="status-top">
      <text class="status-label">今日出摊状态</text>
      <view class="seal {{info.status}}">
        <text>{{info.status === 'started' ? '营业中' : info.status === 'ended' ? '已收摊' : '未出摊'}}</text>
      </view>
    </view>
    <view class="status-headline">
      <view class="dot {{info.status}}"></view>
      <text class="headline-text">{{info.status === 'started' ? '营业中' : info.status === 'ended' ? '已收摊' : '今日尚未出摊'}}</text>
    </view>
    <text class="status-desc">
      {{info.status === 'started' ? '老板已经支好摊子，铁锅正热着 —— 现在过去，拌川管够。' : info.status === 'ended' ? '老板已经收摊了，明天早点来～' : '老板还没出摊，记得关注出摊时间哦～'}}
    </text>
    <text wx:if="{{info.note}}" class="status-note">💬 {{info.note}}</text>
  </view>

  <!-- 地点 / 时间 -->
  <view class="info-grid">
    <view class="info-item info-loc" bindtap="openMap">
      <text class="info-icon">📍</text>
      <text class="info-k">地点</text>
      <text class="info-v">{{info.location}}</text>
      <text class="info-sub">{{info.locationSub}}</text>
      <text class="info-arrow">›</text>
    </view>
    <view class="info-item info-time">
      <text class="info-icon">🕔</text>
      <text class="info-k">时间</text>
      <text class="info-v">{{info.time}}</text>
      <text class="info-sub">{{info.timeSub}}</text>
    </view>
  </view>

  <!-- 分类切换 -->
  <view class="cat-switch-wrapper" wx:if="{{menu.categories && menu.categories.length > 0}}">
    <view class="cat-switch">
      <view class="cat-btn {{activeCat === cat.id ? 'active' : ''}}" wx:for="{{menu.categories}}" wx:for-item="cat" wx:key="id" data-cat="{{cat.id}}" bindtap="switchCat">{{cat.name}}</view>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="menu-group" wx:if="{{menu.categories && menu.categories.length > 0 && menu.products[activeCat] && menu.products[activeCat].length > 0}}">
    <view class="menu-item" wx:for="{{menu.products[activeCat]}}" wx:for-item="product" wx:key="id">
        <view class="menu-thumb">
          <image wx:if="{{product.image}}" class="menu-thumb-img" src="{{product.image}}" mode="aspectFill" />
          <text wx:else class="menu-thumb-emoji">{{product.emoji}}</text>
          <text wx:if="{{product.hot}}" class="hot-tag">招牌</text>
        </view>
      <view class="menu-content">
        <view class="menu-body">
          <text class="menu-name">{{product.name}}</text>
          <text class="menu-desc">{{product.desc}}</text>
        </view>
        <view class="menu-price-box">
          <text class="menu-price">{{product.price}}</text>
          <text wx:if="{{product.priceSuffix}}" class="menu-price-sub">{{product.priceSuffix}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!menu.categories || menu.categories.length === 0}}">
    <text class="empty-icon">🍜</text>
    <text class="empty-text">老板正在准备菜单...</text>
    <text class="empty-subtext">点击标题5次进入设置</text>
  </view>

  <text class="footer-note">灶火不熄 · 明天再见</text>

</view>