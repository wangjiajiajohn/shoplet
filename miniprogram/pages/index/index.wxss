.page {
  position: relative;
  padding: 0 28rpx 60rpx;
  min-height: 100vh;
}

/* 背景装饰光斑，让毛玻璃透出来的颜色更有层次（iOS 液态玻璃常见做法） */
.blob {
  position: fixed;
  border-radius: 50%;
  filter: blur(80rpx);
  z-index: 0;
  pointer-events: none;
}
.blob-1 { width: 460rpx; height: 460rpx; top: -140rpx; right: -120rpx; background: rgba(255, 168, 96, 0.6); }
.blob-2 { width: 380rpx; height: 380rpx; bottom: 220rpx; left: -150rpx; background: rgba(90, 130, 80, 0.4); }
.blob-3 { width: 320rpx; height: 320rpx; bottom: -90rpx; right: -70rpx; background: rgba(196, 90, 58, 0.45); }

/* 玻璃导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  height: calc(var(--status-bar-height) + 96rpx);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 16rpx;
  padding-left: 28rpx;
  padding-right: 28rpx;
  background: rgba(246, 241, 231, 0.48);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
  border-bottom: 1rpx solid rgba(255,255,255,0.6);
  box-shadow:
    0 8rpx 32rpx rgba(92,38,25,0.08),
    inset 0 1rpx 0 rgba(255,255,255,0.8);
}
.nav-title {
  font-size: 36rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  color: #2A1810;
  text-shadow: 0 1rpx 2rpx rgba(255,255,255,0.5);
}

/* 消息滚动栏 */
.scroll-bar-placeholder {
  height: 56rpx;
}
.scroll-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 90;
  height: 56rpx;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  background: rgba(255,235,205,0.9);
  border-bottom: 1rpx solid rgba(255,220,180,0.6);
}
.scroll-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.scroll-track {
  flex: 1;
  overflow: hidden;
  white-space: nowrap;
}
.scroll-text {
  display: inline-block;
  font-size: 24rpx;
  color: #8B4513;
  animation: scroll-left 12s linear infinite;
}
@keyframes scroll-left {
  0% { transform: translateX(100%); }
  100% { transform: translateX(-100%); }
}

/* ---- 通用玻璃卡片 ---- */
.glass {
  background: rgba(255,255,255,0.45);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
  border: 1rpx solid rgba(255,255,255,0.65);
  box-shadow:
    0 20rpx 50rpx rgba(92,38,25,0.14),
    inset 0 1rpx 0 rgba(255,255,255,0.9);
}

/* 状态卡 */
.status-card {
  position: relative;
  z-index: 1;
  background: rgba(255,255,255,0.45);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
  border: 1rpx solid rgba(255,255,255,0.65);
  box-shadow:
    0 20rpx 50rpx rgba(92,38,25,0.14),
    inset 0 1rpx 0 rgba(255,255,255,0.9);
  border-radius: 40rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
}
.status-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.status-label {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: #8A6F5C;
}
.seal {
  min-width: 96rpx;
  padding: 10rpx 12rpx;
  border-radius: 18rpx;
  background: rgba(180,67,46,0.12);
  border: 3rpx solid rgba(180,67,46,0.85);
  color: #B4432E;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  transform: rotate(-6deg);
  backdrop-filter: blur(10rpx);
}
.seal.started {
  border-color: rgba(79,122,74,0.85);
  color: #4F7A4A;
  background: rgba(79,122,74,0.12);
}
.seal.closed {
  border-color: rgba(155,139,120,0.85);
  color: #7A6A56;
  background: rgba(155,139,120,0.12);
}
.seal.ended {
  border-color: rgba(155,139,120,0.85);
  color: #7A6A56;
  background: rgba(155,139,120,0.12);
}
.seal.not_started {
  border-color: rgba(224,138,60,0.85);
  color: #E08A3C;
  background: rgba(224,138,60,0.12);
}
.status-headline {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}
.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 14rpx;
}
.dot.started {
  background: #4F7A4A;
  box-shadow: 0 0 0 6rpx rgba(79,122,74,0.2);
}
.dot.closed {
  background: #9B8B78;
  box-shadow: 0 0 0 6rpx rgba(155,139,120,0.2);
}
.dot.ended {
  background: #9B8B78;
  box-shadow: 0 0 0 6rpx rgba(155,139,120,0.2);
}
.dot.not_started {
  background: #E08A3C;
  box-shadow: 0 0 0 6rpx rgba(224,138,60,0.2);
}
.headline-text {
  font-size: 38rpx;
  font-weight: 700;
  color: #2A1810;
}
.status-desc {
  font-size: 24rpx;
  color: #6B5644;
  line-height: 1.6;
}
.status-note {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #B4622A;
  font-weight: 600;
}

/* 地点/时间 */
.info-grid {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}
.info-item {
  position: relative;
  flex: 1;
  background: rgba(255,255,255,0.4);
  backdrop-filter: blur(35rpx) saturate(180%);
  -webkit-backdrop-filter: blur(35rpx) saturate(180%);
  border: 1rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 14rpx 34rpx rgba(92,38,25,0.1), inset 0 1rpx 0 rgba(255,255,255,0.85);
  border-radius: 32rpx;
  padding: 26rpx;
  display: flex;
  flex-direction: column;
}
.info-icon {
  font-size: 32rpx;
  margin-bottom: 12rpx;
}
.info-k {
  font-size: 20rpx;
  color: #8A6F5C;
  margin-bottom: 6rpx;
}
.info-v {
  font-size: 28rpx;
  font-weight: 600;
  color: #2A1810;
}
.info-sub {
  font-size: 20rpx;
  color: #8A6F5C;
  margin-top: 4rpx;
}
.info-loc {
  cursor: pointer;
}
.info-loc:active {
  background: rgba(255,255,255,0.55);
}
.info-arrow {
  position: absolute;
  right: 26rpx;
  bottom: 26rpx;
  font-size: 32rpx;
  color: #8A6F5C;
  font-weight: 300;
}
.info-time {
  cursor: pointer;
}
.info-time:active {
  background: rgba(255,255,255,0.55);
}

/* 分类切换 —— iOS 分段控件质感 */
.cat-switch-wrapper {
  position: sticky;
  z-index: 50;
  padding-top: 12rpx;
  background: rgba(246,241,231,0.95);
}
.cat-switch {
  display: flex;
  gap: 8rpx;
  margin-bottom: 24rpx;
  background: rgba(255,255,255,0.55);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
  border: 1rpx solid rgba(255,255,255,0.7);
  border-radius: 28rpx;
  padding: 8rpx;
  box-shadow: 0 10rpx 26rpx rgba(92,38,25,0.12);
}
.cat-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx;
  border-radius: 22rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #6B5644;
  transition: all 0.2s ease;
}
.cat-btn.active {
  background: rgba(255,255,255,0.9);
  color: #B4552E;
  box-shadow: 0 6rpx 18rpx rgba(92,38,25,0.15);
}

/* 菜单卡片 */
.menu-container {
  position: relative;
  z-index: 1;
}
.menu-group {
  transition: opacity 0.2s ease;
}
.menu-group-active {
  display: block;
  visibility: visible;
  opacity: 1;
}
.menu-group-hidden {
  display: block;
  visibility: hidden;
  opacity: 0;
  height: 0;
  overflow: hidden;
  position: absolute;
  pointer-events: none;
}

.menu-item {
  display: flex;
  flex-direction: column;
  background: rgba(255,255,255,0.5);
  backdrop-filter: blur(30rpx) saturate(180%);
  -webkit-backdrop-filter: blur(30rpx) saturate(180%);
  border: 1rpx solid rgba(255,255,255,0.7);
  box-shadow: 0 16rpx 36rpx rgba(120,80,40,0.14), inset 0 1rpx 0 rgba(255,255,255,0.9);
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}
.menu-thumb {
  position: relative;
  width: 100%;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.menu-thumb-img {
  width: 100%;
  height: 100%;
  display: block;
}
.menu-thumb-emoji {
  font-size: 130rpx;
  line-height: 1;
}
.hot-tag {
  position: absolute;
  top: 18rpx;
  left: 18rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #FFFFFF;
  background: rgba(196, 90, 58, 0.92);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(120,80,40,0.25);
}
.menu-content {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 26rpx 26rpx;
}
.menu-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}
.menu-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2A1810;
  margin-bottom: 8rpx;
}
.menu-desc {
  font-size: 23rpx;
  color: #8A6F5C;
  line-height: 1.5;
}
.menu-price-box {
  text-align: right;
  flex-shrink: 0;
  padding-top: 4rpx;
}
.menu-price {
  font-size: 34rpx;
  font-weight: 700;
  color: #B4552E;
}
.menu-price-sub {
  display: block;
  font-size: 18rpx;
  color: #8A6F5C;
}

.footer-note {
  position: relative;
  z-index: 1;
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: #8A6F5C;
  margin-top: 40rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255,255,255,0.5);
  letter-spacing: 2rpx;
}

.empty-state {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #2A1810;
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 22rpx;
  color: #8A6F5C;
}
