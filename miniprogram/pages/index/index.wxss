.page {
  position: relative;
  padding: 0 28rpx 60rpx;
  min-height: 100vh;
  background: #FFFFFF;
}

/* ========== Liquid Glass Token System - iOS 26 Style ========== */
.glass-light {
  background: rgba(255,255,255,0.18);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04), inset 0 1rpx 0 rgba(255,255,255,0.8);
}

.glass-medium {
  background: rgba(255,255,255,0.35);
  backdrop-filter: blur(60rpx);
  -webkit-backdrop-filter: blur(60rpx);
  border: 1rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.06), inset 0 1rpx 0 rgba(255,255,255,0.85);
}

.glass-strong {
  background: rgba(255,255,255,0.5);
  backdrop-filter: blur(80rpx);
  -webkit-backdrop-filter: blur(80rpx);
  border: 1rpx solid rgba(255,255,255,0.75);
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.08), inset 0 1rpx 0 rgba(255,255,255,0.9);
}

.radius-sm { border-radius: 20rpx; }
.radius-md { border-radius: 32rpx; }
.radius-lg { border-radius: 48rpx; }

/* ========== 动态背景光斑 - iOS 26 Liquid Glass 核心视觉 ========== */
.blob {
  position: fixed;
  border-radius: 50%;
  filter: blur(160rpx);
  z-index: 0;
  pointer-events: none;
}
.blob-1 { 
  width: 900rpx; 
  height: 900rpx; 
  top: -250rpx; 
  right: -200rpx; 
  background: rgba(255, 180, 130, 0.45);
  animation: blob-move-1 20s ease-in-out infinite;
}
.blob-2 { 
  width: 800rpx; 
  height: 800rpx; 
  bottom: -200rpx; 
  left: -200rpx; 
  background: rgba(255, 220, 180, 0.4);
  animation: blob-move-2 25s ease-in-out infinite;
}
.blob-3 { 
  width: 700rpx; 
  height: 700rpx; 
  top: 500rpx; 
  right: 50rpx; 
  background: rgba(255, 165, 110, 0.3);
  animation: blob-move-3 30s ease-in-out infinite;
}
.blob-4 { 
  width: 600rpx; 
  height: 600rpx; 
  bottom: 200rpx; 
  left: 100rpx; 
  background: rgba(255, 230, 200, 0.35);
  animation: blob-move-4 22s ease-in-out infinite;
}

@keyframes blob-move-1 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(-40rpx, 60rpx) scale(1.1); }
  66% { transform: translate(40rpx, -40rpx) scale(0.9); }
}
@keyframes blob-move-2 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(60rpx, -40rpx) scale(0.95); }
  66% { transform: translate(-40rpx, 80rpx) scale(1.05); }
}
@keyframes blob-move-3 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(-60rpx, -60rpx) scale(1.05); }
  66% { transform: translate(40rpx, 40rpx) scale(0.95); }
}
@keyframes blob-move-4 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(40rpx, 60rpx) scale(0.9); }
  66% { transform: translate(-40rpx, -40rpx) scale(1.1); }
}

/* ========== 玻璃导航栏 ========== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  height: calc(var(--status-bar-height) + 96rpx);
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding-bottom: 16rpx;
  padding-left: 28rpx;
  padding-right: 28rpx;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(60rpx);
  -webkit-backdrop-filter: blur(60rpx);
  border-bottom: 1rpx solid rgba(255,255,255,0.4);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04), inset 0 1rpx 0 rgba(255,255,255,0.6);
}
.nav-left {
  width: 64rpx;
  display: flex;
  align-items: center;
}
.nav-right {
  width: 64rpx;
}
.nav-menu {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255,255,255,0.4);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
}
.nav-menu:active {
  background: rgba(180,85,46,0.1);
  transform: scale(0.95);
}
.menu-icon {
  font-size: 32rpx;
  color: #1A1A1A;
  font-weight: 500;
}
.nav-center {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
}
.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: #1A1A1A;
}
.nav-refresh {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
}
.nav-refresh:active {
  background: rgba(180,85,46,0.1);
  transform: scale(0.95);
}
.refresh-icon {
  font-size: 28rpx;
  color: #666666;
  font-weight: 600;
}
.refresh-icon.loading {
  animation: spin 1s linear infinite;
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ========== 消息滚动栏 ========== */
.scroll-bar-placeholder {
  height: 56rpx;
}
.scroll-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 90;
  height: 56rpx;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  background: rgba(255,240,220,0.6);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-bottom: 1rpx solid rgba(255,220,180,0.4);
}
.scroll-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.scroll-track {
  flex: 1;
  overflow: hidden;
  white-space: nowrap;
}
.scroll-text {
  display: inline-block;
  font-size: 24rpx;
  color: #B4622A;
  animation: scroll-left 12s linear infinite;
}
@keyframes scroll-left {
  0% { transform: translateX(100%); }
  100% { transform: translateX(-100%); }
}

/* ========== 状态卡 ========== */
.status-card {
  position: relative;
  z-index: 1;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  background: rgba(255,255,255,0.4);
  backdrop-filter: blur(60rpx);
  -webkit-backdrop-filter: blur(60rpx);
  border: 1rpx solid rgba(255,255,255,0.6);
  border-radius: 48rpx;
  padding: 32rpx 36rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.06), inset 0 1rpx 0 rgba(255,255,255,0.9);
}
.status-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.status-label {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: #888888;
}
.seal {
  min-width: 96rpx;
  padding: 10rpx 12rpx;
  border-radius: 18rpx;
  background: rgba(180,67,46,0.12);
  border: 3rpx solid rgba(180,67,46,0.85);
  color: #B4432E;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  transform: rotate(-6deg);
  backdrop-filter: blur(10rpx);
}
.seal.started {
  border-color: rgba(79,122,74,0.85);
  color: #4F7A4A;
  background: rgba(79,122,74,0.12);
}
.seal.closed {
  border-color: rgba(155,139,120,0.85);
  color: #7A6A56;
  background: rgba(155,139,120,0.12);
}
.seal.ended {
  border-color: rgba(155,139,120,0.85);
  color: #7A6A56;
  background: rgba(155,139,120,0.12);
}
.seal.not_started {
  border-color: rgba(224,138,60,0.85);
  color: #E08A3C;
  background: rgba(224,138,60,0.12);
}
.status-headline {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}
.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 14rpx;
}
.dot.started {
  background: #4F7A4A;
  box-shadow: 0 0 0 6rpx rgba(79,122,74,0.2);
}
.dot.closed {
  background: #9B8B78;
  box-shadow: 0 0 0 6rpx rgba(155,139,120,0.2);
}
.dot.ended {
  background: #9B8B78;
  box-shadow: 0 0 0 6rpx rgba(155,139,120,0.2);
}
.dot.not_started {
  background: #E08A3C;
  box-shadow: 0 0 0 6rpx rgba(224,138,60,0.2);
}
.headline-text {
  font-size: 42rpx;
  font-weight: 700;
  color: #1A1A1A;
}
.status-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}
.status-note {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #B4622A;
  font-weight: 600;
}

/* ========== 地点/时间信息卡 ========== */
.info-card {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.3);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04), inset 0 1rpx 0 rgba(255,255,255,0.8);
}
.info-left {
  flex: 1;
  display: flex;
  align-items: flex-start;
  cursor: pointer;
}
.info-left:active {
  opacity: 0.7;
}
.info-right {
  flex: 1;
  display: flex;
  align-items: flex-start;
}
.info-divider {
  width: 1rpx;
  height: 80rpx;
  background: rgba(0,0,0,0.06);
  margin: 0 24rpx;
}
.info-icon {
  font-size: 32rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}
.info-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}
.info-row {
  display: flex;
  align-items: center;
}
.info-k {
  font-size: 20rpx;
  color: #888888;
  margin-bottom: 4rpx;
}
.info-v {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A1A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.info-sub {
  font-size: 20rpx;
  color: #888888;
  margin-top: 2rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.info-arrow {
  font-size: 28rpx;
  color: #888888;
  font-weight: 300;
  flex-shrink: 0;
  margin-left: 8rpx;
}

/* ========== 分类切换 —— 果冻胶囊动效 ========== */
.cat-switch-wrapper {
  position: sticky;
  z-index: 50;
}
.cat-switch {
  position: relative;
  display: flex;
  margin-bottom: 24rpx;
  background: rgba(255,255,255,0.3);
  backdrop-filter: blur(60rpx);
  -webkit-backdrop-filter: blur(60rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
  border-radius: 32rpx;
  padding: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04), inset 0 1rpx 0 rgba(255,255,255,0.8);
}
.cat-switch-bg {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  height: calc(100% - 16rpx);
  width: calc(33.33% - 5rpx);
  background: #FFFFFF;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.cat-btn {
  position: relative;
  flex: 1;
  text-align: center;
  padding: 18rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #666666;
  transition: color 0.2s ease;
}
.cat-btn.active {
  color: #B4552E;
}

/* ========== 菜单卡片 ========== */
.menu-container {
  position: relative;
  z-index: 1;
}
.menu-group {
  transition: opacity 0.2s ease;
}
.menu-group-active {
  display: block;
  visibility: visible;
  opacity: 1;
}
.menu-group-hidden {
  display: block;
  visibility: hidden;
  opacity: 0;
  height: 0;
  overflow: hidden;
  position: absolute;
  pointer-events: none;
}

.menu-item {
  display: flex;
  flex-direction: column;
  background: rgba(255,255,255,0.35);
  backdrop-filter: blur(60rpx);
  -webkit-backdrop-filter: blur(60rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 36rpx rgba(0,0,0,0.05), inset 0 1rpx 0 rgba(255,255,255,0.85);
}
.menu-thumb {
  position: relative;
  width: 100%;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.menu-thumb-img {
  width: 100%;
  height: 100%;
  display: block;
}
.menu-thumb-emoji {
  font-size: 130rpx;
  line-height: 1;
}
.hot-tag {
  position: absolute;
  top: 18rpx;
  left: 18rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #FFFFFF;
  background: rgba(220, 100, 80, 0.9);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(220,100,80,0.3);
}
.menu-content {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 24rpx 28rpx 28rpx;
}
.menu-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}
.menu-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}
.menu-desc {
  font-size: 24rpx;
  color: #888888;
  line-height: 1.5;
}
.menu-price-box {
  text-align: right;
  flex-shrink: 0;
  padding-top: 4rpx;
}
.menu-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #B4552E;
}
.menu-price-sub {
  display: block;
  font-size: 18rpx;
  color: #888888;
}

.footer-note {
  position: relative;
  z-index: 1;
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: #AAAAAA;
  margin-top: 40rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(0,0,0,0.05);
  letter-spacing: 2rpx;
}

.empty-state {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 22rpx;
  color: #888888;
}

.contact-card {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.35);
  backdrop-filter: blur(60rpx);
  -webkit-backdrop-filter: blur(60rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 36rpx rgba(0,0,0,0.05), inset 0 1rpx 0 rgba(255,255,255,0.85);
}
.contact-card:active {
  background: rgba(255,255,255,0.5);
}
.contact-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}
.contact-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.contact-label {
  font-size: 22rpx;
  color: #888888;
  margin-bottom: 6rpx;
}
.contact-phone {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
}
.contact-arrow {
  font-size: 32rpx;
  color: #888888;
  font-weight: 300;
}

.qrcode-card {
  position: relative;
  z-index: 1;
  background: rgba(255,255,255,0.35);
  backdrop-filter: blur(60rpx);
  -webkit-backdrop-filter: blur(60rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 12rpx 36rpx rgba(0,0,0,0.05), inset 0 1rpx 0 rgba(255,255,255,0.85);
}
.qrcode-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.qrcode-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}
.qrcode-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}
.qrcode-image {
  width: 240rpx;
  border-radius: 16rpx;
  border: 4rpx solid rgba(255,255,255,0.8);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.08);
}
.qrcode-hint {
  font-size: 22rpx;
  color: #888888;
  margin-top: 16rpx;
  letter-spacing: 2rpx;
}

/* ========== 侧边栏 —— Liquid Glass 风格 ========== */
.sidebar-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.25);
  z-index: 190;
  opacity: 0;
  transition: opacity 0.3s ease;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}

.sidebar-mask.mask-visible {
  opacity: 1;
}

.sidebar {
  position: fixed;
  top: 0;
  left: 0;
  width: 680rpx;
  height: 100vh;
  background: rgba(255,255,255,0.3);
  backdrop-filter: blur(80rpx);
  -webkit-backdrop-filter: blur(80rpx);
  z-index: 200;
  transform: translateX(-100%);
  transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  display: flex;
  flex-direction: column;
  pointer-events: none;
  border-right: 1rpx solid rgba(255,255,255,0.4);
  box-shadow: 8rpx 0 40rpx rgba(0,0,0,0.06), inset 0 1rpx 0 rgba(255,255,255,0.8);
}

.sidebar-open {
  transform: translateX(0);
  pointer-events: auto;
}

.sidebar-header {
  position: relative;
  padding: 0 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(180deg, rgba(255,200,120,0.2) 0%, rgba(255,255,255,0) 100%);
}

.sidebar-close-btn {
  align-self: center;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 32rpx;
  background: rgba(255,255,255,0.4);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border-radius: 50%;
  border: 1rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.close-icon {
  font-size: 48rpx;
  color: #666666;
  font-weight: 400;
}

.sidebar-close-btn:active {
  opacity: 0.6;
  transform: scale(0.95);
}

.user-avatar-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 28rpx;
}

.user-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 6rpx solid rgba(255,255,255,0.8);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}

.user-avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 6rpx solid rgba(255,255,255,0.8);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.4);
}

.avatar-icon {
  font-size: 60rpx;
}

.avatar-edit-btn {
  position: absolute;
  right: -8rpx;
  bottom: -8rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #B4552E;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(180,85,46,0.3);
  cursor: pointer;
}

.avatar-edit-btn:active {
  transform: scale(0.95);
}

.edit-icon {
  font-size: 24rpx;
  color: #FFFFFF;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.user-nickname {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A1A;
  text-align: center;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  max-width: 400rpx;
}

.sidebar-divider {
  height: 20rpx;
  background: rgba(0,0,0,0.02);
}

.sidebar-qrcode {
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.qrcode-container {
  background: rgba(255,255,255,0.35);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-radius: 28rpx;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04), inset 0 1rpx 0 rgba(255,255,255,0.8);
}

.qrcode-img {
  width: 280rpx;
  border-radius: 16rpx;
  border: 4rpx solid rgba(255,255,255,0.8);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.08);
}

.qrcode-hint {
  font-size: 22rpx;
  color: #888888;
  margin-top: 16rpx;
  letter-spacing: 2rpx;
}

.qrcode-tip {
  font-size: 24rpx;
  color: #B4552E;
  margin-top: 8rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.sidebar-menu {
  flex: 1;
  padding: 20rpx 32rpx;
}

.sidebar-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: rgba(255,255,255,0.3);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-radius: 28rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03), inset 0 1rpx 0 rgba(255,255,255,0.8);
}

.sidebar-item:active {
  background: rgba(255,255,255,0.45);
}

.sidebar-item-icon {
  font-size: 36rpx;
  margin-right: 24rpx;
}

.sidebar-item-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.sidebar-item-arrow {
  font-size: 32rpx;
  color: #888888;
  font-weight: 300;
}

.sidebar-footer {
  padding: 16rpx 32rpx 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.footer-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #888888;
}

.footer-version {
  font-size: 20rpx;
  color: #CCCCCC;
}
