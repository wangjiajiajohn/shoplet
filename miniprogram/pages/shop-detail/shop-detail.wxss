.page {
  position: relative;
  min-height: 100vh;
}

.blob {
  position: fixed;
  border-radius: 50%;
  filter: blur(80rpx);
  z-index: 0;
  pointer-events: none;
}
.blob-1 { width: 460rpx; height: 460rpx; top: -140rpx; right: -120rpx; background: rgba(255, 168, 96, 0.6); }
.blob-2 { width: 380rpx; height: 380rpx; bottom: 220rpx; left: -150rpx; background: rgba(90, 130, 80, 0.4); }
.blob-3 { width: 320rpx; height: 320rpx; bottom: -90rpx; right: -70rpx; background: rgba(196, 90, 58, 0.45); }

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  height: 100%;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding-bottom: 16rpx;
  padding-left: 28rpx;
  padding-right: 28rpx;
  background: rgba(246, 241, 231, 0.48);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
  border-bottom: 1rpx solid rgba(255,255,255,0.6);
  box-shadow:
    0 8rpx 32rpx rgba(92,38,25,0.08),
    inset 0 1rpx 0 rgba(255,255,255,0.8);
}
.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
}
.nav-back:active {
  background: rgba(180,85,46,0.2);
}
.back-icon {
  font-size: 48rpx;
  color: #2A1810;
  font-weight: 300;
}
.nav-title {
  font-size: 36rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  color: #2A1810;
  text-shadow: 0 1rpx 2rpx rgba(255,255,255,0.5);
}
.nav-placeholder {
  width: 64rpx;
}

.content {
  padding: 32rpx 28rpx 60rpx;
}

.card {
  position: relative;
  z-index: 1;
  background: rgba(255,255,255,0.45);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
  border: 1rpx solid rgba(255,255,255,0.65);
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 36rpx rgba(120,80,40,0.14), inset 0 1rpx 0 rgba(255,255,255,0.9);
}
.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #2A1810;
  margin-bottom: 8rpx;
}
.card-sub {
  display: block;
  font-size: 22rpx;
  color: #8A6F5C;
  margin-bottom: 20rpx;
}

.qrcode-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
}
.qrcode-image {
  width: 320rpx;
  border-radius: 16rpx;
  border: 4rpx solid rgba(255,255,255,0.8);
  box-shadow: 0 8rpx 20rpx rgba(92,38,25,0.15);
}
.qrcode-placeholder {
  width: 320rpx;
  height: 320rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.3);
  border-radius: 16rpx;
  border: 2rpx dashed rgba(138,111,92,0.3);
}
.placeholder-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}
.placeholder-text {
  font-size: 24rpx;
  color: #8A6F5C;
}

.phone-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}
.phone-row:active {
  opacity: 0.7;
}
.phone-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}
.phone-number {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #2A1810;
}
.phone-arrow {
  font-size: 32rpx;
  color: #8A6F5C;
  font-weight: 300;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(138,111,92,0.1);
}
.info-row:last-child {
  border-bottom: none;
}
.info-label {
  font-size: 26rpx;
  color: #8A6F5C;
}
.info-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #2A1810;
}