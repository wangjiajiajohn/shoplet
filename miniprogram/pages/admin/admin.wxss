.page {
  position: relative;
  padding: 32rpx 28rpx 60rpx;
  min-height: 100vh;
  background: #FFFFFF;
}

/* ========== Liquid Glass Token System - iOS 26 Style ========== */
.glass-light {
  background: rgba(255,255,255,0.18);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04), inset 0 1rpx 0 rgba(255,255,255,0.8);
}

.glass-medium {
  background: rgba(255,255,255,0.35);
  backdrop-filter: blur(60rpx);
  -webkit-backdrop-filter: blur(60rpx);
  border: 1rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.06), inset 0 1rpx 0 rgba(255,255,255,0.85);
}

.glass-strong {
  background: rgba(255,255,255,0.5);
  backdrop-filter: blur(80rpx);
  -webkit-backdrop-filter: blur(80rpx);
  border: 1rpx solid rgba(255,255,255,0.75);
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.08), inset 0 1rpx 0 rgba(255,255,255,0.9);
}

.radius-sm { border-radius: 20rpx; }
.radius-md { border-radius: 32rpx; }
.radius-lg { border-radius: 48rpx; }

/* ========== 动态背景光斑 ========== */
.blob {
  position: fixed;
  border-radius: 50%;
  filter: blur(160rpx);
  z-index: 0;
  pointer-events: none;
}
.blob-1 { 
  width: 800rpx; 
  height: 800rpx; 
  top: -200rpx; 
  left: -200rpx; 
  background: rgba(255, 180, 120, 0.5);
  animation: blob-move-1 20s ease-in-out infinite;
}
.blob-2 { 
  width: 700rpx; 
  height: 700rpx; 
  bottom: -150rpx; 
  right: -180rpx; 
  background: rgba(120, 200, 160, 0.45);
  animation: blob-move-2 25s ease-in-out infinite;
}
.blob-3 { 
  width: 600rpx; 
  height: 600rpx; 
  top: 400rpx; 
  left: 100rpx; 
  background: rgba(220, 140, 180, 0.35);
  animation: blob-move-3 30s ease-in-out infinite;
}

@keyframes blob-move-1 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(-40rpx, 60rpx) scale(1.1); }
  66% { transform: translate(40rpx, -40rpx) scale(0.9); }
}
@keyframes blob-move-2 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(60rpx, -40rpx) scale(0.95); }
  66% { transform: translate(-40rpx, 80rpx) scale(1.05); }
}
@keyframes blob-move-3 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(-60rpx, -60rpx) scale(1.05); }
  66% { transform: translate(40rpx, 40rpx) scale(0.95); }
}

/* ========== Tab切换 —— 果冻胶囊动效 ========== */
.tab-wrapper {
  position: fixed;
  top: calc(var(--status-bar-height) + 44px);
  left: 28rpx;
  right: 28rpx;
  z-index: 100;
  display: flex;
  position: relative;
  background: rgba(255,255,255,0.3);
  backdrop-filter: blur(60rpx);
  -webkit-backdrop-filter: blur(60rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
  border-radius: 32rpx;
  padding: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04), inset 0 1rpx 0 rgba(255,255,255,0.8);
}
.tab-bg {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  height: calc(100% - 16rpx);
  width: calc(33.33% - 5rpx);
  background: #FFFFFF;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.tab-placeholder {
  height: 120rpx;
}
.tab-item {
  position: relative;
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 28rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #666666;
  transition: color 0.2s ease;
}
.tab-item.active {
  color: #B4552E;
}

.tab-content {
  position: relative;
  z-index: 1;
}

.panel-title {
  position: relative;
  z-index: 1;
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}
.panel-sub {
  position: relative;
  z-index: 1;
  display: block;
  font-size: 22rpx;
  color: #888888;
  margin-bottom: 40rpx;
}

.field {
  position: relative;
  z-index: 1;
  margin-bottom: 36rpx;
}
.field-label {
  display: block;
  font-size: 22rpx;
  color: #888888;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}
.field-hint {
  display: block;
  font-size: 20rpx;
  color: #AAAAAA;
  margin-bottom: 12rpx;
}

/* ========== 营业状态切换 —— 玻璃分段控件 ========== */
.toggle-row {
  display: flex;
  background: rgba(255,255,255,0.3);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04), inset 0 1rpx 0 rgba(255,255,255,0.8);
  border-radius: 32rpx;
  padding: 8rpx;
}
.toggle-opt {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #666666;
  transition: all 0.2s ease;
}
.toggle-opt.sel {
  background: rgba(79,122,74,0.85);
  color: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(79,122,74,0.3);
}

/* ========== 输入展示框 ========== */
.input-fake {
  background: rgba(255,255,255,0.35);
  backdrop-filter: blur(60rpx);
  -webkit-backdrop-filter: blur(60rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04), inset 0 1rpx 0 rgba(255,255,255,0.85);
  border-radius: 32rpx;
  padding: 26rpx 28rpx;
  font-size: 28rpx;
  color: #1A1A1A;
}
.loc-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
}
.loc-picker:active {
  background: rgba(255,255,255,0.5);
}
.loc-arrow {
  font-size: 32rpx;
  color: #888888;
  font-weight: 300;
}
.input-real {
  background: rgba(255,255,255,0.35);
  backdrop-filter: blur(60rpx);
  -webkit-backdrop-filter: blur(60rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04), inset 0 1rpx 0 rgba(255,255,255,0.85);
  border-radius: 32rpx;
  padding: 26rpx 28rpx;
  font-size: 26rpx;
  color: #1A1A1A;
}

.preset-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}
.preset {
  font-size: 22rpx;
  padding: 14rpx 22rpx;
  border-radius: 30rpx;
  background: rgba(255,255,255,0.3);
  backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
  color: #666666;
}
.preset.sel {
  border-color: rgba(224,138,60,0.9);
  color: #b4622a;
  background: rgba(224,138,60,0.15);
}

/* ========== 保存按钮 ========== */
.save-btn {
  position: relative;
  z-index: 1;
  width: 100%;
  background: rgba(180,85,46,0.92);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255,255,255,0.3);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  padding: 24rpx 0;
  border-radius: 32rpx;
  margin-top: 20rpx;
  box-shadow: 0 12rpx 32rpx rgba(180,85,46,0.3), inset 0 1rpx 0 rgba(255,255,255,0.2);
}
.save-btn::after {
  border: none;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.add-btn {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(79,122,74,0.85);
  color: #ffffff;
  font-weight: 600;
}

/* ========== 分类卡片 ========== */
.category-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.category-card {
  background: rgba(255,255,255,0.35);
  backdrop-filter: blur(60rpx);
  -webkit-backdrop-filter: blur(60rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
  border-radius: 32rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04), inset 0 1rpx 0 rgba(255,255,255,0.85);
}
.category-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
}
.category-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}
.category-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}
.category-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}
.action-btn.edit {
  background: rgba(224,138,60,0.15);
  color: #b4622a;
}
.action-btn.delete {
  background: rgba(180,67,46,0.15);
  color: #b4432e;
}

/* ========== 商品列表 ========== */
.product-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.product-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: rgba(255,255,255,0.3);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.5);
}
.product-emoji {
  font-size: 32rpx;
  margin-right: 14rpx;
}
.product-image {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

/* ========== 图片上传区域 ========== */
.image-upload-area {
  width: 200rpx;
  height: 200rpx;
  border-radius: 24rpx;
  border: 2rpx dashed rgba(0,0,0,0.1);
  background: rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.upload-preview {
  width: 100%;
  height: 100%;
}
.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.upload-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}
.upload-text {
  font-size: 22rpx;
  color: #888888;
}
.image-actions {
  margin-top: 12rpx;
}
.product-info {
  flex: 1;
}
.product-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1A1A1A;
}
.product-price {
  font-size: 22rpx;
  color: #B4552E;
}
.product-actions {
  display: flex;
  gap: 10rpx;
}

.add-product-btn {
  text-align: center;
  font-size: 24rpx;
  padding: 14rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.25);
  color: #666666;
  border: 1rpx dashed rgba(0,0,0,0.1);
}

/* ========== 弹窗 ========== */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}
.modal-content {
  width: 600rpx;
  background: rgba(255,255,255,0.6);
  backdrop-filter: blur(80rpx);
  -webkit-backdrop-filter: blur(80rpx);
  border: 1rpx solid rgba(255,255,255,0.8);
  border-radius: 48rpx;
  padding: 48rpx;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.08), inset 0 1rpx 0 rgba(255,255,255,0.9);
}
.modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A1A;
  text-align: center;
  margin-bottom: 32rpx;
}
.modal-field {
  margin-bottom: 24rpx;
}
.modal-label {
  display: block;
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 10rpx;
}
.modal-input {
  width: 100%;
  background: rgba(255,255,255,0.5);
  border: 1rpx solid rgba(255,255,255,0.6);
  border-radius: 24rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #1A1A1A;
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
}
.emoji-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.emoji-option {
  font-size: 40rpx;
  padding: 10rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.4);
}
.emoji-option:active {
  background: rgba(224,138,60,0.2);
}
.selected-emoji {
  font-size: 36rpx;
  display: block;
  text-align: center;
}
.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}
.modal-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 28rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.modal-btn.cancel {
  background: rgba(255,255,255,0.4);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
  color: #666666;
}
.modal-btn.confirm {
  background: rgba(79,122,74,0.85);
  color: #ffffff;
}
.modal-btn::after {
  border: none;
}

.toggle-row.small {
  width: fit-content;
  padding: 4rpx;
}
.toggle-row.small .toggle-opt {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}
