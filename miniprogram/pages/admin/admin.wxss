.page {
  position: relative;
  padding: 32rpx 28rpx 60rpx;
  min-height: 100vh;
}

.blob {
  position: fixed;
  border-radius: 50%;
  filter: blur(80rpx);
  z-index: 0;
  pointer-events: none;
}
.blob-1 { width: 460rpx; height: 460rpx; top: -140rpx; left: -120rpx; background: rgba(255, 168, 96, 0.6); }
.blob-2 { width: 340rpx; height: 340rpx; bottom: 280rpx; right: -130rpx; background: rgba(90, 130, 80, 0.35); }

.panel-title {
  position: relative;
  z-index: 1;
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #2A1810;
  margin-bottom: 8rpx;
  text-shadow: 0 1rpx 2rpx rgba(255,255,255,0.4);
}
.panel-sub {
  position: relative;
  z-index: 1;
  display: block;
  font-size: 22rpx;
  color: #6B5644;
  margin-bottom: 40rpx;
}

.field {
  position: relative;
  z-index: 1;
  margin-bottom: 36rpx;
}
.field-label {
  display: block;
  font-size: 22rpx;
  color: #6B5644;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

/* 营业状态切换 —— 玻璃分段控件 */
.toggle-row {
  display: flex;
  background: rgba(255,255,255,0.4);
  backdrop-filter: blur(30rpx) saturate(180%);
  -webkit-backdrop-filter: blur(30rpx) saturate(180%);
  border: 1rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 10rpx 26rpx rgba(92,38,25,0.1);
  border-radius: 28rpx;
  padding: 8rpx;
}
.toggle-opt {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 22rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #6B5644;
  transition: all 0.2s ease;
}
.toggle-opt.on {
  background: rgba(79,122,74,0.85);
  color: #FFFFFF;
  box-shadow: 0 6rpx 18rpx rgba(79,122,74,0.3);
}
.toggle-opt.off {
  background: rgba(155,139,120,0.85);
  color: #FFFFFF;
  box-shadow: 0 6rpx 18rpx rgba(155,139,120,0.3);
}

/* 输入展示框 */
.input-fake {
  background: rgba(255,255,255,0.4);
  backdrop-filter: blur(30rpx) saturate(180%);
  -webkit-backdrop-filter: blur(30rpx) saturate(180%);
  border: 1rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 10rpx 26rpx rgba(92,38,25,0.1), inset 0 1rpx 0 rgba(255,255,255,0.85);
  border-radius: 24rpx;
  padding: 26rpx 28rpx;
  font-size: 28rpx;
  color: #2A1810;
}
.input-real {
  background: rgba(255,255,255,0.4);
  backdrop-filter: blur(30rpx) saturate(180%);
  -webkit-backdrop-filter: blur(30rpx) saturate(180%);
  border: 1rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 10rpx 26rpx rgba(92,38,25,0.1), inset 0 1rpx 0 rgba(255,255,255,0.85);
  border-radius: 24rpx;
  padding: 26rpx 28rpx;
  font-size: 26rpx;
  color: #2A1810;
}

.preset-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}
.preset {
  font-size: 22rpx;
  padding: 14rpx 22rpx;
  border-radius: 30rpx;
  background: rgba(255,255,255,0.35);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
  color: #6B5644;
}
.preset.sel {
  border-color: rgba(224,138,60,0.9);
  color: #B4622A;
  background: rgba(224,138,60,0.15);
}

.save-btn {
  position: relative;
  z-index: 1;
  width: 100%;
  background: rgba(180,85,46,0.92);
  backdrop-filter: blur(30rpx) saturate(180%);
  -webkit-backdrop-filter: blur(30rpx) saturate(180%);
  border: 1rpx solid rgba(255,255,255,0.3);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  padding: 24rpx 0;
  border-radius: 28rpx;
  margin-top: 20rpx;
  box-shadow: 0 16rpx 40rpx rgba(92,38,25,0.35), inset 0 1rpx 0 rgba(255,255,255,0.25);
}
.save-btn::after {
  border: none;
}
