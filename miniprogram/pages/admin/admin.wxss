.page {
  position: relative;
  padding: 32rpx 28rpx 60rpx;
  min-height: 100vh;
}

.blob {
  position: fixed;
  border-radius: 50%;
  filter: blur(80rpx);
  z-index: 0;
  pointer-events: none;
}
.blob-1 { width: 460rpx; height: 460rpx; top: -140rpx; left: -120rpx; background: rgba(255, 168, 96, 0.6); }
.blob-2 { width: 340rpx; height: 340rpx; bottom: 280rpx; right: -130rpx; background: rgba(90, 130, 80, 0.35); }

.tab-wrapper {
  position: fixed;
  top: calc(var(--status-bar-height) + 44px);
  left: 28rpx;
  right: 28rpx;
  z-index: 100;
  display: flex;
  background: rgba(246, 241, 231, 0.95);
  backdrop-filter: blur(30rpx) saturate(180%);
  -webkit-backdrop-filter: blur(30rpx) saturate(180%);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 10rpx 26rpx rgba(92, 38, 25, 0.1);
  border-radius: 28rpx;
  padding: 8rpx;
}
.tab-placeholder {
  height: 120rpx;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #6b5644;
  transition: all 0.2s ease;
}
.tab-item.active {
  background: rgba(255, 255, 255, 0.9);
  color: #b4552e;
  box-shadow: 0 6rpx 18rpx rgba(92, 38, 25, 0.15);
}

.tab-content {
  position: relative;
  z-index: 1;
}

.panel-title {
  position: relative;
  z-index: 1;
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #2A1810;
  margin-bottom: 8rpx;
  text-shadow: 0 1rpx 2rpx rgba(255, 255, 255, 0.4);
}
.panel-sub {
  position: relative;
  z-index: 1;
  display: block;
  font-size: 22rpx;
  color: #6b5644;
  margin-bottom: 40rpx;
}

.field {
  position: relative;
  z-index: 1;
  margin-bottom: 36rpx;
}
.field-label {
  display: block;
  font-size: 22rpx;
  color: #6b5644;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}
.field-hint {
  display: block;
  font-size: 20rpx;
  color: #9a8b78;
  margin-bottom: 12rpx;
}

/* 营业状态切换 —— 玻璃分段控件 */
.toggle-row {
  display: flex;
  background: rgba(255,255,255,0.4);
  backdrop-filter: blur(30rpx) saturate(180%);
  -webkit-backdrop-filter: blur(30rpx) saturate(180%);
  border: 1rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 10rpx 26rpx rgba(92,38,25,0.1);
  border-radius: 28rpx;
  padding: 8rpx;
}
.toggle-opt {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 22rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #6b5644;
  transition: all 0.2s ease;
}
.toggle-opt.sel {
  background: rgba(79,122,74,0.85);
  color: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(79,122,74,0.3);
}

/* 输入展示框 */
.input-fake {
  background: rgba(255,255,255,0.4);
  backdrop-filter: blur(30rpx) saturate(180%);
  -webkit-backdrop-filter: blur(30rpx) saturate(180%);
  border: 1rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 10rpx 26rpx rgba(92,38,25,0.1), inset 0 1rpx 0 rgba(255,255,255,0.85);
  border-radius: 24rpx;
  padding: 26rpx 28rpx;
  font-size: 28rpx;
  color: #2a1810;
}
.loc-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
}
.loc-picker:active {
  background: rgba(255,255,255,0.55);
}
.loc-arrow {
  font-size: 32rpx;
  color: #8a6f5c;
  font-weight: 300;
}
.input-real {
  background: rgba(255,255,255,0.4);
  backdrop-filter: blur(30rpx) saturate(180%);
  -webkit-backdrop-filter: blur(30rpx) saturate(180%);
  border: 1rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 10rpx 26rpx rgba(92,38,25,0.1), inset 0 1rpx 0 rgba(255,255,255,0.85);
  border-radius: 24rpx;
  padding: 26rpx 28rpx;
  font-size: 26rpx;
  color: #2a1810;
}

.preset-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}
.preset {
  font-size: 22rpx;
  padding: 14rpx 22rpx;
  border-radius: 30rpx;
  background: rgba(255,255,255,0.35);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
  color: #6b5644;
}
.preset.sel {
  border-color: rgba(224,138,60,0.9);
  color: #b4622a;
  background: rgba(224,138,60,0.15);
}

.save-btn {
  position: relative;
  z-index: 1;
  width: 100%;
  background: rgba(180,85,46,0.92);
  backdrop-filter: blur(30rpx) saturate(180%);
  -webkit-backdrop-filter: blur(30rpx) saturate(180%);
  border: 1rpx solid rgba(255,255,255,0.3);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  padding: 24rpx 0;
  border-radius: 28rpx;
  margin-top: 20rpx;
  box-shadow: 0 16rpx 40rpx rgba(92,38,25,0.35), inset 0 1rpx 0 rgba(255,255,255,0.25);
}
.save-btn::after {
  border: none;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.add-btn {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(79,122,74,0.85);
  color: #ffffff;
  font-weight: 600;
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.category-card {
  background: rgba(255,255,255,0.4);
  backdrop-filter: blur(30rpx) saturate(180%);
  -webkit-backdrop-filter: blur(30rpx) saturate(180%);
  border: 1rpx solid rgba(255,255,255,0.6);
  border-radius: 24rpx;
  padding: 20rpx;
}
.category-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(138,111,92,0.15);
}
.category-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}
.category-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #2a1810;
}
.category-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}
.action-btn.edit {
  background: rgba(224,138,60,0.15);
  color: #b4622a;
}
.action-btn.delete {
  background: rgba(180,67,46,0.15);
  color: #b4432e;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.product-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: rgba(255,255,255,0.5);
  border-radius: 16rpx;
}
.product-emoji {
  font-size: 32rpx;
  margin-right: 14rpx;
}
.product-image {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.image-upload-area {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  border: 2rpx dashed rgba(138,111,92,0.3);
  background: rgba(255,255,255,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.upload-preview {
  width: 100%;
  height: 100%;
}
.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.upload-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}
.upload-text {
  font-size: 22rpx;
  color: #8a6f5c;
}
.image-actions {
  margin-top: 12rpx;
}
.product-info {
  flex: 1;
}
.product-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #2a1810;
}
.product-price {
  font-size: 22rpx;
  color: #b4552e;
}
.product-actions {
  display: flex;
  gap: 10rpx;
}

.add-product-btn {
  text-align: center;
  font-size: 24rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.3);
  color: #6b5644;
  border: 1rpx dashed rgba(138,111,92,0.3);
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.modal-content {
  width: 600rpx;
  background: #fff8f0;
  border-radius: 32rpx;
  padding: 40rpx;
  max-height: 80vh;
  overflow-y: auto;
}
.modal-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #2a1810;
  text-align: center;
  margin-bottom: 32rpx;
}
.modal-field {
  margin-bottom: 24rpx;
}
.modal-label {
  display: block;
  font-size: 24rpx;
  color: #6b5644;
  margin-bottom: 10rpx;
}
.modal-input {
  width: 100%;
  background: rgba(255,255,255,0.6);
  border: 1rpx solid rgba(138,111,92,0.2);
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #2a1810;
}
.emoji-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.emoji-option {
  font-size: 40rpx;
  padding: 10rpx;
  border-radius: 12rpx;
  background: rgba(255,255,255,0.6);
}
.emoji-option:active {
  background: rgba(224,138,60,0.2);
}
.selected-emoji {
  font-size: 36rpx;
  display: block;
  text-align: center;
}
.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}
.modal-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.modal-btn.cancel {
  background: rgba(138,111,92,0.15);
  color: #6b5644;
}
.modal-btn.confirm {
  background: rgba(79,122,74,0.85);
  color: #ffffff;
}
.modal-btn::after {
  border: none;
}

.toggle-row.small {
  width: fit-content;
  padding: 4rpx;
}
.toggle-row.small .toggle-opt {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}
