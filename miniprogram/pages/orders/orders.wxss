.page {
  position: relative;
  min-height: 100vh;
  background: #F6F1E7;
}

.blob {
  position: fixed;
  border-radius: 50%;
  filter: blur(80rpx);
  z-index: 0;
  pointer-events: none;
}
.blob-1 { width: 460rpx; height: 460rpx; top: -140rpx; right: -120rpx; background: rgba(255, 168, 96, 0.6); }
.blob-2 { width: 380rpx; height: 380rpx; bottom: 220rpx; left: -150rpx; background: rgba(90, 130, 80, 0.4); }
.blob-3 { width: 320rpx; height: 320rpx; bottom: -90rpx; right: -70rpx; background: rgba(196, 90, 58, 0.45); }

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 28rpx;
  padding-right: 28rpx;
  background: rgba(246, 241, 231, 0.9);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-bottom: 1rpx solid rgba(255,255,255,0.6);
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #2A1810;
  font-weight: 300;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2A1810;
}

.nav-placeholder {
  width: 64rpx;
}

.content {
  position: relative;
  z-index: 1;
  padding: 0 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #2A1810;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #8A6F5C;
}